#!/bin/bash
set -e

REPO_DIR="$(cd "$(dirname "$(realpath "${BASH_SOURCE[0]}")")/.." && pwd)"

cmd_update() {
    git -C "$REPO_DIR" pull
}

cmd_devcontainer() {
    local SRC_DIR="$REPO_DIR/devcontainer"
    local DEST_DIR="$(pwd)/.devcontainer"
    local PRESERVE=(allowed_domains.txt devcontainer.json)
    local CONTAINER_NAME=""

    while [[ "${1:-}" == --* ]]; do
        case "$1" in
            --name) CONTAINER_NAME="$2"; shift 2 ;;
            *) echo "unknown option: $1"; exit 1 ;;
        esac
    done

    is_preserved() {
        local rel="$1"
        for name in "${PRESERVE[@]}"; do
            [[ "$rel" == *"$name" ]] && return 0
        done
        return 1
    }

    mkdir -p "$DEST_DIR"

    while IFS= read -r -d '' src; do
        rel="${src#$SRC_DIR/}"
        dest="$DEST_DIR/$rel"
        if is_preserved "$rel" && [ -e "$dest" ]; then
            echo "skip: $dest"
            continue
        fi
        mkdir -p "$(dirname "$dest")"
        cp "$src" "$dest"
        echo "copied: $dest"
    done < <(find "$SRC_DIR" -type f -print0)

    if [[ -n "$CONTAINER_NAME" ]]; then
        local dc_json="$DEST_DIR/devcontainer.json"
        sed -i "s/\"name\": \"[^\"]*\"/\"name\": \"$CONTAINER_NAME\"/" "$dc_json"
        echo "set name: $CONTAINER_NAME"
    fi

    if ! docker volume inspect shared-pnpm-store &>/dev/null; then
        docker volume create shared-pnpm-store
        echo "created docker volume: shared-pnpm-store"
    else
        echo "ok: docker volume shared-pnpm-store already exists"
    fi

    echo "done. edit $DEST_DIR/firewall/allowed_domains.txt to control which domains the dev container can reach."
}

case "${1:-}" in
    update)       cmd_update ;;
    devcontainer) shift; cmd_devcontainer "$@" ;;
    *)
        echo "usage: devenv <command>"
        echo ""
        echo "commands:"
        echo "  update          pull the latest devenv repo"
        echo "  devcontainer [--name <name>]    copy/update .devcontainer in the current project"
        exit 1
        ;;
esac
