#!/bin/bash
set -e

REPO_DIR="$(cd "$(dirname "$(realpath "${BASH_SOURCE[0]}")")/.." && pwd)"
WORKTREES_DIR="$REPO_DIR/worktrees"
LIB_DIR="$REPO_DIR/lib"

for lib in "$LIB_DIR"/*.sh; do
    source "$lib"
done

case "${1:-}" in
    update)            cmd_update ;;
    devcontainer)      shift; cmd_devcontainer "$@" ;;
    install-extension) shift; cmd_install_extension "$@" ;;
    clone)             shift; cmd_clone "$@" ;;
    worktree)          shift; cmd_worktree "$@" ;;
    container)         shift; cmd_container "$@" ;;
    agent)             shift; cmd_agent "$@" ;;
    dashboard)         shift; cmd_dashboard "$@" ;;
    *)
        echo "usage: devenv <command>"
        echo ""
        echo "commands:"
        echo "  update                          pull the latest devenv repo"
        echo "  devcontainer [--name <name>]    (legacy) copy/update .devcontainer in the current project"
        echo "  install-extension [--skip-build] install the egress approver VS Code extension on Windows"
        echo "  clone <url> [name]              bare-clone a repo into worktrees/<name>/.git + checkout its default branch"
        echo "  worktree add <repo> <branch> [base]   add a worktree at worktrees/<repo>/<branch>"
        echo "  worktree rm [<repo> <branch>] [--force] remove a worktree (fzf picker if omitted)"
        echo "  worktree list [repo]            list worktrees for one repo, or all repos"
        echo "  container up [<repo> <branch>] [--code]    build/start a worktree's dev container stack (fzf picker if omitted; --code opens VS Code attached)"
        echo "  container down [<repo> <branch>]           stop a worktree's dev container stack (fzf picker if omitted)"
        echo "  container attach [<repo> <branch>] [--code] exec a zsh shell in a running dev container (fzf picker if omitted; --code opens VS Code instead of a shell)"
        echo "  container list                  list running devenv-managed containers"
        echo "  agent up [<repo> <branch>] [name] [-- claude-args...]  start a background claude agent in a worktree container (starts the container if needed)"
        echo "  agent attach <repo> <branch> [name]        attach to a background agent (fzf picker if name omitted/ambiguous)"
        echo "  agent rm <repo> <branch> [name]            remove a background agent from claude's session list (fzf picker if name omitted/ambiguous)"
        echo "  agent list [repo] [branch]      list background agents (running worktree containers, or one)"
        echo "  dashboard                       launch the Ink TUI for monitoring worktrees/containers/agents"
        exit 1
        ;;
esac
