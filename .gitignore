.DS_Store
node_modules/
devcontainer/infra/approver/package-lock.json
devcontainer/infra/approver/bun.lock
*.tgz
dist/

# Host-generated approver token (never committed). Lives next to the compose file
# so Docker Compose auto-loads it for ${APPROVER_TOKEN} substitution.
.devcontainer/.env
devcontainer/.env

# Live shared allowlist, seeded once from *.default (see lib/container.sh
# _shared_seed_firewall). Edit these, not the .default templates.
devcontainer/infra/firewall/allowed_domains.txt
devcontainer/infra/firewall/denied_domains.txt

# Claude Code runtime state (machine-local, never committed)
.claude/worktrees/
.claude/settings.local.json

# repos cloned via `devenv clone` / `devenv worktree` (machine-local)
/worktrees/*
!/worktrees/.gitkeep
