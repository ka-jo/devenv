{
  "name": "devcontainer",
  "dockerComposeFile": "docker-compose.yml",
  "service": "devcontainer",
  "workspaceFolder": "/workspace",
  "customizations": {
    "vscode": {
      "settings": {
        "claudeCode.allowDangerouslySkipPermissions": true,
        "claudeCode.initialPermissionMode": "bypassPermissions",
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "bash",
            "icon": "terminal-bash"
          },
          "zsh": {
            "path": "zsh"
          }
        }
      },
      "extensions": [
        "Vue.volar",
        "ms-dotnettools.csdevkit",
        "oxc.oxc-vscode",
        "vitest.explorer",
        "usernamehw.errorlens",
        "EditorConfig.EditorConfig",
        "anthropic.claude-code"
      ]
    }
  },
  "remoteUser": "ka-jo",
  "containerUser": "ka-jo",
  "remoteEnv": {
    "HISTFILE": "/home/ka-jo/commandhistory/.zsh_history"
  },
  "mounts": [
    {
      "source": "ka-jo-zsh-history",
      "target": "/home/ka-jo/commandhistory",
      "type": "volume"
    }
  ],
  "onCreateCommand": "sudo chown ka-jo:ka-jo /home/ka-jo/.pnpm-store",
  "postCreateCommand": {
    "linkDevenv": "ln -sf /home/ka-jo/devenv/scripts/devenv /home/ka-jo/.local/bin/devenv",
    "installNode": "fnm install",
    "installDeps": "pnpm install"
  },
  "postStartCommand": "zsh /workspace/.devcontainer/firewall/verify.sh"
}
